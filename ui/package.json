  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "autobuild": "vite build --watch",
    "prettier": "oxfmt --check \"**/*.{ts,json,css,html,svelte}\"",
    "prettier:fix": "oxfmt --write \"**/*.{ts,json,css,html,svelte}\"",
    "format": "npm run prettier:fix",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch --coverage",
    "locales": "npx typesafe-i18n --no-watch",
    "locales:watch": "typesafe-i18n"
  },
  "dependencies": {
    "@lucide/svelte": "^0.574.0",
    "compute-scroll-into-view": "^3.1.1",
    "d3-scale": "^4.0.2",
    "focus-trap": "^8.2.1",
    "he": "^1.2.0",
    "js-cookie": "^3.0.8",
    "navaid": "^1.2.0",
    "quill": "^1.3.7",
    "snapsvg-cjs": "^0.0.6",
    "sockette": "^2.0.6",
    "svelte-dnd-action": "^0.9.70"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/js-cookie": "^3.0.6",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/browser-preview": "^4.1.9",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "oxfmt": "^0.55.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^14.0.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "typesafe-i18n": "^5.27.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  }
