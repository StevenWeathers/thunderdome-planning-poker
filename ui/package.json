{
  "name": "thunderdome-planning-poker",
  "version": "0.0.1",
  "description": "Planning Poker App",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StevenWeathers/thunderdome-planning-poker.git"
  },
  "author": "Steven Weathers",
